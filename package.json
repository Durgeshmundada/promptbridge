{
  "name": "promptbridge",
  "version": "1.0.0",
  "private": true,
  "description": "PromptBridge Chrome extension scaffold powered by React, TypeScript, Zustand, Tailwind CSS, and Vite.",
  "scripts": {
    "prebuild": "node --experimental-strip-types scripts/generate-icons.ts",
    "dev": "vite",
    "build": "vite build",
    "server": "node --env-file=.env.server.local --import tsx server/index.ts",
    "import:templates": "node --env-file=.env.server.local --import tsx scripts/importPromptTemplates.ts",
    "generate:icons": "node --experimental-strip-types scripts/generate-icons.ts",
    "package": "node --experimental-strip-types scripts/package.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongodb": "^7.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.0.299",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.18",
    "vite-plugin-web-extension": "npm:@samrum/vite-plugin-web-extension@^5.1.1",
    "yazl": "^3.3.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/src"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "testMatch": [
      "**/?(*.)+(spec|test).(ts|tsx)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "target": "ES2020",
            "module": "commonjs",
            "jsx": "react-jsx"
          }
        }
      ]
    },
    "passWithNoTests": true
  }
}
